# Generate: openssl rand -base64 32
JWT_SECRET=

# OpenRouter — get key at openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: override the default model (default: anthropic/claude-sonnet-4-5)
# OPENROUTER_MODEL=openai/gpt-4o

# Generate: node scripts/generate-vapid-keys.js
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your@email.com

# Railway sets these automatically
NODE_ENV=development
PORT=3000

# Railway volume mount point (set to /data in Railway)
DATA_PATH=./data
